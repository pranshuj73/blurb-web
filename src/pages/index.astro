---
import BaseHead from '../components/BaseHead.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../config';
---

<!DOCTYPE html>
<html lang="en-us">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=IBM+Plex+Sans:wght@300;400;500;600&display=swap"
		/>
	</head>
	<body>
		<header class="site-header">
			<div class="container header-inner">
				<div class="logo">
					<span class="logo-mark"></span>
					<span>{SITE_TITLE}</span>
				</div>
				<nav class="nav">
					<a href="/privacy-policy">Privacy</a>
					<a class="cta" href="#early-access">Get early access</a>
				</nav>
			</div>
		</header>

		<main>
			<section class="hero">
				<div class="hero-grid">
					<div class="hero-copy">
						<p class="eyebrow">Minimalist QR cards for real-world intros</p>
						<h1>Share a link in seconds. No handles. No numbers.</h1>
						<p class="lead">
							Save your site once, tap to show a clean QR, and let people open your profile
							instantly.
						</p>
						<div class="actions">
							<a class="cta" href="#early-access">Join the waitlist</a>
							<a class="ghost" href="#flow">See the flow</a>
						</div>
						<div class="micro-proof">
							<span>Instant scan</span>
							<span>Privacy-first</span>
							<span>One-tap share</span>
						</div>
					</div>
					<div class="hero-media">
						<div class="hero-photo">
							<img
								src="https://images.unsplash.com/photo-1521737604893-d14cc237f11d?auto=format&fit=crop&w=1400&q=80"
								alt="Friends connecting at a creative meetup"
								loading="lazy"
							/>
						</div>
						<div class="hero-ui">
							<div class="phone">
								<div class="phone-notch"></div>
								<div class="screen dark">
									<div class="screen-content">
										<div class="screen-top">
											<div class="screen-status">
												<span></span><span></span><span></span>
											</div>
										</div>
										<div class="screen-brand">blurb.</div>
										<div class="screen-divider"></div>
										<div class="card-list">
											<div class="card dark-card">
												<div class="card-main">
													<div class="card-badge">
														<img class="card-icon" src="/icons/icon-192.png" alt="" />
													</div>
													<div>
														<p class="card-title">prnsh</p>
														<p class="card-sub">prnsh.site</p>
													</div>
												</div>
												<div class="card-pill qr">QR</div>
											</div>
											<div class="card dark-card">
												<div class="card-main">
													<div class="card-badge">
														<img class="card-icon" src="/icons/icon-192.png" alt="" />
													</div>
													<div>
														<p class="card-title">X</p>
														<p class="card-sub">x.com/prnshtwt</p>
													</div>
												</div>
												<div class="card-pill qr">QR</div>
											</div>
											<div class="card dark-card">
												<div class="card-main">
													<div class="card-badge">
														<img class="card-icon" src="/icons/icon-192.png" alt="" />
													</div>
													<div>
														<p class="card-title">LinkedIn</p>
														<p class="card-sub">linkedin.com</p>
													</div>
												</div>
												<div class="card-pill qr">QR</div>
											</div>
										</div>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
				<div class="hero-glow"></div>
			</section>

			<section id="flow" class="flow">
				<div class="container flow-grid">
					<div class="flow-copy">
						<h2>Three steps, no friction.</h2>
						<p>Create a card, share instantly, connect without the awkward follow-up.</p>
					</div>
					<ol class="flow-steps">
						<li>
							<h3>Create a card</h3>
							<p>Paste a website or social link and save it to your list.</p>
						</li>
						<li>
							<h3>Share instantly</h3>
							<p>Tap a card to open a fullscreen QR ready to scan.</p>
						</li>
						<li>
							<h3>Connect without friction</h3>
							<p>They scan and land on your profile. No searching. No phone swap.</p>
						</li>
					</ol>
				</div>
			</section>

			<section class="features">
				<div class="container features-grid">
					<div>
						<h2>Built for the moment you meet.</h2>
						<p>Clean UI, instant QR, and a tidy card list you can update anytime.</p>
						<ul>
							<li>Fullscreen QR with high-contrast scan targets.</li>
							<li>Multiple cards so you choose what to share.</li>
							<li>Share a link, not your number.</li>
						</ul>
					</div>
					<div class="feature-panel">
						<p class="panel-label">Live moment view</p>
						<div class="panel-screen">
							<div class="panel-card">
								<div>
									<p class="name">prnsh</p>
									<p class="role">prnsh.site</p>
								</div>
								<div class="qr-mini"></div>
							</div>
							<div class="panel-card ghost">
								<div>
									<p class="name">X</p>
									<p class="role">x.com/prnshtwt</p>
								</div>
								<div class="qr-mini"></div>
							</div>
						</div>
						<p class="panel-note">Tap a card → show QR instantly.</p>
					</div>
				</div>
			</section>

			<section class="detail">
				<div class="container detail-grid">
					<div class="detail-copy">
						<h2>Your links, your control.</h2>
						<p>Pick what to share and keep personal contact info private.</p>
						<a class="text-link" href="/privacy-policy">Read the privacy policy</a>
					</div>
					<div class="detail-media">
						<div class="detail-image">
							<img
								src="https://images.unsplash.com/photo-1521791136064-7986c2920216?auto=format&fit=crop&w=1200&q=80"
								alt="People talking during a conference break"
								loading="lazy"
							/>
						</div>
						<div class="detail-panel">
							<p class="detail-label">Card setup</p>
							<div class="detail-row">
								<span>Title</span>
								<strong>Portfolio</strong>
							</div>
							<div class="detail-row">
								<span>Link</span>
								<strong>prnsh.site</strong>
							</div>
							<button type="button">Save card</button>
						</div>
					</div>
				</div>
			</section>

			<section id="early-access" class="cta-section">
				<div class="container cta-grid">
					<div>
						<h2>Be ready for the next intro.</h2>
						<p>Join the early list and get first access when Blurb launches.</p>
					</div>
					<div class="cta-actions">
						<a class="cta" href="mailto:hello@blurb.app">Request early access</a>
						<span>hello@blurb.app</span>
					</div>
				</div>
			</section>
		</main>

		<footer class="site-footer">
			<div class="container footer-inner">
				<p>Blurb is a minimalist digital card app for in-person networking.</p>
				<div class="footer-links">
					<a href="/privacy-policy">Privacy policy</a>
					<a href="mailto:hello@blurb.app">Contact</a>
				</div>
			</div>
		</footer>
	</body>
</html>

<style>
:global(body) {
	margin: 0;
	padding: 0;
	max-width: 100%;
	font-family: 'IBM Plex Sans', system-ui, -apple-system, sans-serif;
	color: #121212;
	background: #f3f1ec;
}

:global(*) {
	box-sizing: border-box;
}

:global(a) {
	color: inherit;
	text-decoration: none;
}

main {
	overflow: hidden;
}

.container {
	width: min(1120px, 90vw);
	margin: 0 auto;
}

.site-header {
	position: sticky;
	top: 0;
	z-index: 10;
	background: rgba(243, 241, 236, 0.9);
	backdrop-filter: blur(12px);
	border-bottom: 1px solid rgba(18, 18, 18, 0.08);
}

.header-inner {
	display: flex;
	align-items: center;
	justify-content: space-between;
	padding: 18px 0;
}

.logo {
	display: flex;
	align-items: center;
	gap: 12px;
	font-family: 'Space Grotesk', sans-serif;
	font-weight: 600;
	letter-spacing: -0.02em;
}

.logo-mark {
	width: 14px;
	height: 14px;
	background: #111;
	border-radius: 50%;
	box-shadow: 0 0 0 6px rgba(17, 17, 17, 0.15);
	animation: pulse 5s ease-in-out infinite;
}

.nav {
	display: flex;
	gap: 18px;
	align-items: center;
	font-size: 0.95rem;
}

.cta {
	background: #111;
	color: #f7f4ef;
	padding: 12px 22px;
	border-radius: 999px;
	font-weight: 500;
	transition: transform 0.2s ease, box-shadow 0.2s ease;
	box-shadow: 0 12px 24px rgba(0, 0, 0, 0.2);
}

.cta:hover {
	transform: translateY(-2px);
	box-shadow: 0 16px 30px rgba(0, 0, 0, 0.25);
}

.hero {
	position: relative;
	padding: 96px 0 80px;
	background: linear-gradient(120deg, #f7f5f0 0%, #ece8df 45%, #e0dfdb 100%);
}

.hero-grid {
	width: min(1200px, 92vw);
	margin: 0 auto;
	display: grid;
	grid-template-columns: repeat(2, minmax(0, 1fr));
	gap: 48px;
	align-items: center;
}

.hero-copy {
	display: grid;
	gap: 18px;
	max-width: 520px;
	animation: rise 0.8s ease-out both;
}

.eyebrow {
	text-transform: uppercase;
	letter-spacing: 0.22em;
	font-size: 0.72rem;
	color: #5b5b5b;
	font-weight: 600;
}

.hero h1 {
	font-family: 'Space Grotesk', sans-serif;
	font-size: clamp(2.4rem, 4vw, 3.8rem);
	letter-spacing: -0.03em;
	margin: 0;
}

.lead {
	font-size: 1.1rem;
	color: #333;
	line-height: 1.7;
}

.actions {
	display: flex;
	gap: 16px;
	flex-wrap: wrap;
}

.ghost {
	border: 1px solid rgba(17, 17, 17, 0.2);
	padding: 12px 20px;
	border-radius: 999px;
	transition: border 0.2s ease, transform 0.2s ease;
	font-weight: 500;
}

.ghost:hover {
	border-color: rgba(17, 17, 17, 0.5);
	transform: translateY(-2px);
}

.micro-proof {
	display: flex;
	gap: 18px;
	font-size: 0.9rem;
	color: #666;
}

.hero-media {
	position: relative;
	display: grid;
	gap: 24px;
	padding-bottom: 60px;
	animation: fadeIn 0.9s ease-out both 0.2s;
}

.hero-photo {
	border-radius: 28px;
	overflow: hidden;
	box-shadow: 0 26px 50px rgba(0, 0, 0, 0.2);
}

.hero-photo img {
	width: 100%;
	height: 520px;
	object-fit: cover;
	display: block;
}

.hero-ui {
	position: absolute;
	bottom: -40px;
	left: 36px;
	display: grid;
	gap: 18px;
}

.phone {
	position: relative;
	border-radius: 36px;
	background: #0e0e0e;
	padding: 18px;
	box-shadow: 0 36px 70px rgba(0, 0, 0, 0.4);
}

.phone-notch {
	width: 140px;
	height: 20px;
	background: #1c1c1c;
	border-radius: 999px;
	margin: 0 auto 16px;
}

.screen {
	background: #f7f4ef;
	border-radius: 26px;
	padding: 20px;
	display: grid;
	gap: 16px;
	min-height: 460px;
}

.screen-content {
	display: grid;
	gap: 16px;
	transform: scale(0.75);
	transform-origin: top left;
	width: 133.333%;
}

.screen.dark {
	background: radial-gradient(circle at top, #1b1d20 0%, #0b0c0e 60%, #050505 100%);
	color: #f4f4f2;
	box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.05);
}

.screen-top {
	display: flex;
	justify-content: flex-end;
	align-items: center;
	font-size: 0.75rem;
	letter-spacing: 0.06em;
	color: rgba(244, 244, 242, 0.7);
}

.screen-status {
	display: flex;
	gap: 4px;
}

.screen-status span {
	width: 10px;
	height: 6px;
	border-radius: 999px;
	background: rgba(244, 244, 242, 0.6);
}

.screen-brand {
	font-family: 'Space Grotesk', sans-serif;
	font-size: 1.7rem;
	font-weight: 600;
	letter-spacing: -0.02em;
}

.screen-divider {
	height: 1px;
	background: rgba(255, 255, 255, 0.08);
}

.card-list {
	display: grid;
	gap: 14px;
}

.screen-header {
	display: flex;
	justify-content: space-between;
	align-items: center;
	font-weight: 600;
}

.card {
	display: flex;
	justify-content: space-between;
	align-items: center;
	padding: 14px 16px;
	border-radius: 16px;
	background: linear-gradient(135deg, #ffffff 0%, #f7f6f2 100%);
	border: 1px solid rgba(17, 17, 17, 0.08);
	box-shadow: 0 12px 24px rgba(0, 0, 0, 0.08);
	animation: rise 1s ease-out both;
}

.card.dark-card {
	background: linear-gradient(135deg, rgba(34, 36, 40, 0.9), rgba(16, 17, 19, 0.9));
	border: 1px solid rgba(255, 255, 255, 0.08);
	box-shadow: 0 18px 30px rgba(0, 0, 0, 0.35);
}

.card.ghost {
	opacity: 0.6;
}

.card-main {
	display: flex;
	align-items: center;
	gap: 12px;
}

.card-icon {
	width: 32px;
	height: 32px;
	border-radius: 10px;
	background: #111;
	padding: 6px;
	box-shadow: 0 10px 18px rgba(0, 0, 0, 0.12);
	display: block;
}

.card-badge {
	width: 44px;
	height: 44px;
	border-radius: 14px;
	background: #0f0f12;
	display: grid;
	place-items: center;
	box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.05);
}

.card-title {
	margin: 0;
	font-weight: 600;
	font-size: 0.98rem;
}

.card-sub {
	margin: 4px 0 0;
	font-size: 0.85rem;
	color: #666;
}

.dark-card .card-title {
	color: #f2f2f0;
}

.dark-card .card-sub {
	color: rgba(244, 244, 242, 0.7);
}

.card-pill {
	background: #111;
	color: #f7f4ef;
	border-radius: 999px;
	padding: 6px 12px;
	font-size: 0.78rem;
	font-weight: 600;
	display: inline-flex;
	align-items: center;
	gap: 6px;
}

.dark-card .card-pill {
	background: rgba(255, 255, 255, 0.12);
	color: #f4f4f2;
	border: 1px solid rgba(255, 255, 255, 0.2);
}

.card-pill.qr::before {
	content: '';
	width: 8px;
	height: 8px;
	border-radius: 2px;
	background: #f7f4ef;
}

.panel-qr-grid {
	display: grid;
	grid-template-columns: repeat(5, 1fr);
	gap: 6px;
}

.panel-qr-grid span {
	display: block;
	width: 18px;
	height: 18px;
	background: #f9f6f1;
}

.hero-glow {
	position: absolute;
	width: 320px;
	height: 320px;
	border-radius: 50%;
	background: radial-gradient(circle, rgba(17, 17, 17, 0.18), transparent 70%);
	top: 8%;
	right: 6%;
	filter: blur(6px);
	opacity: 0.4;
}

.flow {
	padding: 90px 0;
	background: #fdfcf9;
}

.flow-grid {
	display: grid;
	grid-template-columns: 0.9fr 1.1fr;
	gap: 48px;
	align-items: start;
}

.flow-copy {
	display: grid;
	gap: 12px;
}

.flow h2,
.features h2,
.detail h2,
.cta-section h2 {
	font-family: 'Space Grotesk', sans-serif;
	font-size: clamp(1.9rem, 3vw, 2.6rem);
	margin: 0;
}

.flow-steps {
	list-style: none;
	margin: 0;
	padding: 0;
	display: grid;
	gap: 18px;
}

.flow-steps li {
	padding: 22px 24px;
	border: 1px solid rgba(17, 17, 17, 0.08);
	border-radius: 18px;
	background: #ffffff;
	box-shadow: 0 18px 40px rgba(17, 17, 17, 0.08);
	animation: rise 0.9s ease-out both;
}

.flow-steps h3 {
	margin: 0 0 10px;
	font-family: 'Space Grotesk', sans-serif;
}

.flow-steps p {
	margin: 0;
	color: #4b4b4b;
}

.features {
	padding: 90px 0;
	background: #f2efe8;
}

.features-grid {
	display: grid;
	grid-template-columns: 1fr 0.9fr;
	gap: 48px;
	align-items: center;
}

.features ul {
	margin: 18px 0 0;
	padding-left: 20px;
	color: #3d3d3d;
	line-height: 1.7;
}

.feature-panel {
	background: #141414;
	color: #f9f6f1;
	padding: 28px;
	border-radius: 24px;
	display: grid;
	gap: 18px;
	box-shadow: 0 24px 50px rgba(0, 0, 0, 0.25);
}

.panel-label {
	text-transform: uppercase;
	letter-spacing: 0.3em;
	font-size: 0.7rem;
	color: rgba(255, 255, 255, 0.6);
}

.panel-screen {
	display: grid;
	gap: 14px;
}

.panel-card {
	display: flex;
	justify-content: space-between;
	align-items: center;
	background: rgba(255, 255, 255, 0.08);
	border-radius: 16px;
	padding: 16px 18px;
}

.panel-card.ghost {
	opacity: 0.6;
}

.name {
	margin: 0;
	font-weight: 600;
}

.role {
	margin: 4px 0 0;
	font-size: 0.85rem;
	color: rgba(255, 255, 255, 0.7);
}

.qr-mini {
	width: 44px;
	height: 44px;
	border-radius: 10px;
	background: repeating-linear-gradient(135deg, #f9f6f1, #f9f6f1 6px, #1a1a1a 6px, #1a1a1a 12px);
}

.panel-note {
	font-size: 0.85rem;
	color: rgba(255, 255, 255, 0.6);
}

.detail {
	padding: 100px 0;
	background: #f9f7f1;
}

.detail-grid {
	display: grid;
	grid-template-columns: 0.9fr 1.1fr;
	gap: 48px;
	align-items: center;
}

.detail-copy {
	display: grid;
	gap: 16px;
}

.text-link {
	font-weight: 600;
	border-bottom: 1px solid rgba(17, 17, 17, 0.2);
	width: fit-content;
	padding-bottom: 4px;
}

.detail-panel {
	background: #ffffff;
	border-radius: 22px;
	padding: 24px;
	display: grid;
	gap: 14px;
	box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
}

.detail-label {
	text-transform: uppercase;
	letter-spacing: 0.25em;
	font-size: 0.7rem;
	color: #6b6b6b;
	margin: 0;
}

.detail-row {
	display: flex;
	justify-content: space-between;
	font-size: 0.95rem;
}

.detail-row span {
	color: #6b6b6b;
}

.detail-panel button {
	border: none;
	border-radius: 999px;
	padding: 12px 16px;
	background: #111;
	color: #f7f4ef;
	font-weight: 600;
	cursor: pointer;
}

.detail-media {
	display: grid;
	gap: 18px;
}

.detail-image {
	border-radius: 20px;
	overflow: hidden;
	box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
}

.detail-image img {
	width: 100%;
	height: 220px;
	object-fit: cover;
	display: block;
}

.cta-section {
	padding: 80px 0 100px;
	background: #121212;
	color: #f8f4ef;
}

.cta-grid {
	display: flex;
	justify-content: space-between;
	gap: 32px;
	align-items: center;
}

.cta-actions {
	display: grid;
	gap: 14px;
	justify-items: start;
}

.cta-actions span {
	color: rgba(248, 244, 239, 0.7);
	font-size: 0.95rem;
}

.site-footer {
	background: #0b0b0b;
	color: rgba(248, 244, 239, 0.7);
	padding: 40px 0;
}

.footer-inner {
	display: flex;
	justify-content: space-between;
	gap: 24px;
	font-size: 0.95rem;
}

.footer-links {
	display: flex;
	gap: 18px;
}

@keyframes rise {
	from {
		opacity: 0;
		transform: translateY(16px);
	}
	to {
		opacity: 1;
		transform: translateY(0);
	}
}

@keyframes fadeIn {
	from {
		opacity: 0;
		transform: scale(0.98);
	}
	to {
		opacity: 1;
		transform: scale(1);
	}
}

@keyframes pulse {
	0%,
	100% {
		box-shadow: 0 0 0 6px rgba(17, 17, 17, 0.15);
	}
	50% {
		box-shadow: 0 0 0 12px rgba(17, 17, 17, 0.08);
	}
}

@media (max-width: 900px) {
	.header-inner {
		flex-direction: column;
		gap: 12px;
	}

	.hero-grid,
	.flow-grid,
	.features-grid,
	.detail-grid {
		grid-template-columns: 1fr;
	}

	.hero-ui {
		position: static;
	}

	.cta-grid,
	.footer-inner {
		flex-direction: column;
		align-items: flex-start;
