---
import BaseHead from '../components/BaseHead.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../config';
---

<!DOCTYPE html>
<html lang="en-us">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Instrument+Serif:opsz@8..144&family=IBM+Plex+Sans:wght@300;400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap"
		/>
	</head>
	<body>
		<header class="site-header">
			<div class="container header-inner">
				<div class="logo">Blurb</div>
				<nav class="nav">
					<a href="#flow">Flow</a>
					<a class="pill" href="#contact">Contact</a>
				</nav>
			</div>
		</header>

		<main>
			<section class="hero" id="top">
				<div class="container hero-grid">
					<div class="hero-copy">
					<p class="eyebrow">Digital business cards</p>
					<h1>Share your site in one scan.</h1>
					<p class="lead">Blurb turns any link into a QR card you can show instantly.</p>
					<div class="hero-actions">
						<a class="cta" href="#flow">See the flow</a>
						<a class="ghost" href="#contact">Contact</a>
					</div>
					</div>
					<div class="hero-media">
						<div class="giant-qr" aria-hidden="true">
							<svg viewBox="0 0 120 120" role="presentation">
								<rect width="120" height="120" fill="white" />
								<g fill="black">
									<rect x="8" y="8" width="24" height="24" />
									<rect x="88" y="8" width="24" height="24" />
									<rect x="8" y="88" width="24" height="24" />
									<rect x="44" y="44" width="12" height="12" />
									<rect x="60" y="44" width="12" height="12" />
									<rect x="44" y="60" width="12" height="12" />
									<rect x="60" y="60" width="12" height="12" />
									<rect x="72" y="28" width="8" height="8" />
									<rect x="28" y="72" width="8" height="8" />
								</g>
							</svg>
						</div>
						<div class="device">
							<div class="device-speaker"></div>
							<div class="device-screen">
								<div class="device-brand">blurb.</div>
								<div class="device-qr">
									<svg class="qr-svg" viewBox="0 0 120 120" role="img" aria-label="QR code">
										<rect width="120" height="120" fill="#f5f5f5" />
										<g fill="#0d0d0d">
											<rect x="8" y="8" width="28" height="28" />
											<rect x="84" y="8" width="28" height="28" />
											<rect x="8" y="84" width="28" height="28" />
											<rect x="48" y="48" width="10" height="10" />
											<rect x="60" y="48" width="10" height="10" />
											<rect x="72" y="48" width="10" height="10" />
											<rect x="48" y="60" width="10" height="10" />
											<rect x="60" y="60" width="10" height="10" />
											<rect x="72" y="60" width="10" height="10" />
											<rect x="48" y="72" width="10" height="10" />
											<rect x="60" y="72" width="10" height="10" />
											<rect x="72" y="72" width="10" height="10" />
										</g>
									</svg>
								</div>
								<div class="device-caption">Scan to open</div>
								<div class="device-url">prnsh.site</div>
							</div>
						</div>
					</div>
				</div>
			</section>

			<section id="flow" class="flow">
				<div class="container flow-head">
					<h2>Three steps. That’s it.</h2>
					<p>Blurb removes the awkward part of networking.</p>
				</div>
				<div class="flow-rail">
					<article class="flow-panel">
						<span class="flow-index">01</span>
						<h3>Create a card</h3>
						<p>Paste a website or social link and save it.</p>
						<div class="flow-visual phone-list">
							<div class="flow-card">
								<span>prnsh.site</span>
								<span class="badge">QR</span>
							</div>
							<div class="flow-card muted">
								<span>x.com/prnshtwt</span>
								<span class="badge">QR</span>
							</div>
						</div>
					</article>
					<article class="flow-panel">
						<span class="flow-index">02</span>
						<h3>Show the QR</h3>
						<p>Tap a card and the QR fills the screen.</p>
						<div class="flow-visual qr-full">
							<div class="qr-frame">
								<svg class="qr-svg" viewBox="0 0 120 120" role="presentation">
									<rect width="120" height="120" fill="#f5f5f5" />
									<g fill="#0d0d0d">
										<rect x="8" y="8" width="28" height="28" />
										<rect x="84" y="8" width="28" height="28" />
										<rect x="8" y="84" width="28" height="28" />
										<rect x="48" y="48" width="10" height="10" />
										<rect x="60" y="48" width="10" height="10" />
										<rect x="72" y="48" width="10" height="10" />
										<rect x="48" y="60" width="10" height="10" />
										<rect x="60" y="60" width="10" height="10" />
										<rect x="72" y="60" width="10" height="10" />
										<rect x="48" y="72" width="10" height="10" />
										<rect x="60" y="72" width="10" height="10" />
										<rect x="72" y="72" width="10" height="10" />
									</g>
								</svg>
							</div>
							<span class="qr-label">prnsh.site</span>
						</div>
					</article>
					<article class="flow-panel">
						<span class="flow-index">03</span>
						<h3>They open your page</h3>
						<p>One scan. Your site loads instantly.</p>
						<div class="flow-visual scan">
							<div class="scan-ring"></div>
							<div class="scan-dot"></div>
							<span>Open in browser</span>
						</div>
					</article>
				</div>
			</section>

			<section class="features">
				<div class="container feature-head">
					<h2>Built for real moments.</h2>
				<p>Clean, fast, and built for in-person sharing.</p>
				</div>
				<div class="container feature-grid">
					<div class="feature-card">
						<h3>Instant QR</h3>
					<p>Every card generates a scannable code automatically.</p>
					</div>
					<div class="feature-card">
						<h3>Multiple cards</h3>
					<p>Share different links depending on the moment.</p>
					</div>
					<div class="feature-card">
						<h3>Privacy first</h3>
						<p>Share a link. Keep your number private.</p>
					</div>
					<div class="feature-card">
						<h3>Always ready</h3>
						<p>Open the app and the QR is seconds away.</p>
					</div>
				</div>
			</section>

			<section class="qr-moment">
				<div class="container qr-wrap">
					<div class="qr-copy">
						<h2>The moment of connection.</h2>
						<p>A quick scan replaces the awkward exchange.</p>
					</div>
					<div class="qr-stage">
						<span class="qr-mode">QR view</span>
					<svg class="qr-svg xl" viewBox="0 0 120 120" role="presentation">
						<rect width="120" height="120" fill="#f5f5f5" />
						<g fill="#0d0d0d">
								<rect x="8" y="8" width="28" height="28" />
								<rect x="84" y="8" width="28" height="28" />
								<rect x="8" y="84" width="28" height="28" />
								<rect x="48" y="48" width="10" height="10" />
								<rect x="60" y="48" width="10" height="10" />
								<rect x="72" y="48" width="10" height="10" />
								<rect x="48" y="60" width="10" height="10" />
								<rect x="60" y="60" width="10" height="10" />
								<rect x="72" y="60" width="10" height="10" />
								<rect x="48" y="72" width="10" height="10" />
								<rect x="60" y="72" width="10" height="10" />
								<rect x="72" y="72" width="10" height="10" />
							</g>
					</svg>
					<span class="qr-url">prnsh.site</span>
					<span class="qr-ritual">Scan → open</span>
				</div>
			</div>
		</section>

			<section id="contact" class="contact">
				<div class="container contact-inner">
					<div>
						<h2>Questions?</h2>
						<p>Reach out for feedback, partnerships, or support.</p>
					</div>
					<div class="contact-actions">
						<a class="cta" href="mailto:hey@prnsh.site">Email</a>
						<span>hey@prnsh.site</span>
					</div>
				</div>
			</section>
		</main>

		<footer class="site-footer">
			<div class="container footer-inner">
				<p>Blurb — QR business cards for real-world intros.</p>
				<a href="mailto:hey@prnsh.site">Contact</a>
			</div>
		</footer>
	</body>
</html>

<style>
:global(:root) {
	--bg: #f6f4ef;
	--ink: #0d0d0d;
	--ink-soft: #2c2c2c;
	--muted: #7b7b7b;
	--paper: #ffffff;
	--line: rgba(0, 0, 0, 0.12);
	--accent: #0d0d0d;
	--accent-soft: rgba(0, 0, 0, 0.08);
	--grain: rgba(0, 0, 0, 0.03);
	--shadow-soft: 0 10px 30px rgba(0, 0, 0, 0.08);
	--shadow-float: 0 40px 80px rgba(0, 0, 0, 0.18);
	--shadow-device: 0 60px 120px rgba(0, 0, 0, 0.35);
	--radius-lg: 24px;
	--radius-md: 14px;
	--radius-sm: 8px;
	--radius-pill: 999px;
	--ease: cubic-bezier(0.22, 1, 0.36, 1);
	\196px\3
	--hero-pad: clamp(6rem, 10vh, 10rem);
	\156px\3
	\1500px\3
	\11.06rem\3
	\1480px\3
	--hero-bg: radial-gradient(circle at 40% 30%, #ffffff 0%, #f6f4ef 45%, #ece9e2 100%);
	\1400px\3
	\10.04\3
	\1min(360px, 68vw)\3
	\126px\3
	\124px\3
	--device-screen-min: 440px;
	\1170px\3
	\120px\3
	\126px\3
	\112px\3
	\1#efece6\3
	\10.92rem\3
	--feature-gap: 18px;
	--feature-card-pad: 28px;
	--feature-card-min: 180px;
	--feature-alt: #fcfbf8;
	--qr-stage-pad: 40px;
	--qr-size: 320px;
	--contact-pad: 70px;
	--footer-pad-top: 36px;
}

:global(body) {
	margin: 0;
	padding: 0;
	max-width: 100%;
	font-family: 'Sohne', 'IBM Plex Sans', sans-serif;
	font-size: 1.05rem;
	color: var(--ink);
	background: var(--bg);
	line-height: 1.6;
}

:global(body)::before {
	content: '';
	position: fixed;
	inset: 0;
	pointer-events: none;
	opacity: 0.22;
	mix-blend-mode: multiply;
	background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='220' height='220'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='3'/></filter><rect width='220' height='220' filter='url(%23n)' opacity='0.25'/></svg>");
	z-index: 0;
}

:global(body)::after {
	content: '';
	position: fixed;
	inset: -10% 0 0 0;
	pointer-events: none;
	background: radial-gradient(circle at 50% 20%, rgba(255, 255, 255, 0.6), transparent 70%);
	opacity: 0.7;
	z-index: 0;
}

:global(*) {
	box-sizing: border-box;
}

:global(a) {
	color: inherit;
	text-decoration: none;
}

main {
	position: relative;
	z-index: 1;
}

.container {
	width: min(1180px, 90vw);
	margin: 0 auto;
}

.site-header {
	position: sticky;
	top: 0;
	z-index: 10;
	background: rgba(246, 244, 239, 0.7);
	backdrop-filter: blur(10px);
	border-bottom: 1px solid var(--line);
}

.header-inner {
	display: flex;
	align-items: center;
	justify-content: space-between;
	padding: 18px 0;
}

.logo {
	font-family: 'Canela', 'Instrument Serif', serif;
	font-size: 1.2rem;
	letter-spacing: -0.02em;
}

.nav {
	display: flex;
	gap: 18px;
	align-items: center;
	font-size: 0.95rem;
}

.pill {
	border: 1px solid var(--line);
	padding: 10px 18px;
	border-radius: var(--radius-pill);
}

.hero {
	background: var(--hero-bg);
	padding: var(--hero-pad) 0;
	overflow: hidden;
}

.hero-grid {
	display: grid;
	grid-template-columns: 5fr 7fr;
	gap: var(--hero-gap);
	align-items: center;
}

.hero-copy {
	display: grid;
	gap: 22px;
	max-width: var(--hero-max-width);
}

.eyebrow {
	font-size: 0.75rem;
	letter-spacing: 0.14em;
	text-transform: uppercase;
	color: var(--muted);
	font-family: 'IBM Plex Mono', monospace;
}

.hero h1 {
	font-family: 'Canela', 'Instrument Serif', serif;
	font-weight: 500;
	font-size: clamp(3rem, 5vw, 5.2rem);
	letter-spacing: -0.02em;
	line-height: 1.03;
	margin: 0;
}

.lead {
	font-size: var(--hero-lead-size);
	color: var(--ink-soft);
	margin: 0;
	max-width: var(--hero-lead-width);
}

.hero-actions {
	display: flex;
	gap: 14px;
	flex-wrap: wrap;
}

.cta {
	background: var(--accent);
	color: var(--paper);
	padding: 11px 22px;
	border-radius: var(--radius-pill);
	font-weight: 500;
	transition: transform 0.3s var(--ease), box-shadow 0.3s var(--ease);
	box-shadow: var(--shadow-soft);
}

.cta:hover {
	transform: translateY(-2px);
	box-shadow: var(--shadow-float);
}

.ghost {
	border: 1px solid var(--line);
	padding: 11px 20px;
	border-radius: var(--radius-pill);
	transition: border 0.3s var(--ease), transform 0.3s var(--ease);
}

.ghost:hover {
	border-color: var(--ink-soft);
	transform: translateY(-2px);
}

.hero-media {
	position: relative;
	display: grid;
	place-items: center;
}

.giant-qr {
	position: absolute;
	right: -40px;
	top: -40px;
	width: var(--hero-qr-size);
	height: var(--hero-qr-size);
	opacity: var(--hero-qr-opacity);
}

.giant-qr svg {
	width: 100%;
	height: 100%;
}

.device {
	position: relative;
	width: var(--device-width);
	border-radius: 38px;
	background: #0b0c0e;
	padding: var(--device-pad);
	box-shadow: var(--shadow-device);
	transform: rotate(-4deg);
	animation: floatIn 0.9s var(--ease) both 0.4s;
}

.device-speaker {
	width: 160px;
	height: 16px;
	border-radius: 999px;
	background: #151618;
	margin: 0 auto 18px;
}

.device-screen {
	background: linear-gradient(160deg, #111317 0%, #070707 60%, #050505 100%);
	border-radius: 28px;
	padding: var(--device-screen-pad);
	min-height: var(--device-screen-min);
	color: #f4f4f2;
	display: grid;
	gap: 20px;
	justify-items: center;
	text-align: center;
	box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.06);
}

.device-brand {
	font-family: 'Canela', 'Instrument Serif', serif;
	font-size: 1.6rem;
	justify-self: start;
}

.device-qr {
	width: var(--device-qr-size);
	height: var(--device-qr-size);
	border-radius: 20px;
	background: #f5f5f5;
	padding: 12px;
	box-shadow: var(--shadow-soft);
}

.qr-svg {
	width: 100%;
	height: 100%;
}

.device-caption {
	font-size: 0.85rem;
	letter-spacing: 0.14em;
	text-transform: uppercase;
	color: rgba(244, 244, 242, 0.6);
	font-family: 'IBM Plex Mono', monospace;
}

.device-url {
	font-size: 1.05rem;
	font-weight: 500;
}

.flow {
	padding: var(--section-pad) 0;
}

.flow-head {
	display: grid;
	gap: 10px;
	margin-bottom: 28px;
}

.flow-head h2 {
	font-family: 'Canela', 'Instrument Serif', serif;
	font-size: clamp(2rem, 3vw, 3rem);
	margin: 0;
}

.flow-rail {
	display: grid;
	grid-auto-flow: column;
	grid-auto-columns: minmax(280px, 420px);
	gap: var(--flow-gap);
	overflow-x: auto;
	scroll-snap-type: x mandatory;
	padding: var(--flow-rail-pad) 0 var(--flow-rail-pad) 5vw;
}

.flow-panel {
	background: var(--paper);
	border: 1px solid var(--line);
	border-radius: var(--radius-lg);
	padding: var(--flow-panel-pad);
	display: grid;
	gap: 14px;
	min-height: 320px;
	scroll-snap-align: start;
	box-shadow: var(--shadow-soft);
}

.flow-index {
	font-family: 'IBM Plex Mono', monospace;
	color: var(--muted);
	letter-spacing: 0.18em;
	font-size: 0.75rem;
	text-transform: uppercase;
}

.flow-panel h3 {
	margin: 0;
	font-size: clamp(1.4rem, 2vw, 1.8rem);
	line-height: 1.15;
}

.flow-panel p {
	margin: 0;
	color: var(--ink-soft);
}

.flow-visual {
	margin-top: auto;
	padding: 16px;
	border-radius: 18px;
	background: var(--flow-visual-bg);
	display: grid;
	gap: 12px;
}

.flow-card {
	display: flex;
	justify-content: space-between;
	padding: 12px 14px;
	border-radius: 14px;
	background: #fff;
	border: 1px solid var(--line);
	font-size: var(--flow-card-font);
}

.flow-card.muted {
	opacity: 0.7;
}

.badge {
	font-size: 0.75rem;
	border: 1px solid var(--line);
	padding: 4px 10px;
	border-radius: var(--radius-pill);
}

.qr-full .qr-frame {
	background: #fff;
	border-radius: 16px;
	padding: 12px;
	box-shadow: var(--shadow-soft);
}

.qr-label {
	font-size: 0.85rem;
	font-family: 'IBM Plex Mono', monospace;
	color: var(--muted);
}

.scan {
	display: grid;
	place-items: center;
	gap: 12px;
	position: relative;
	min-height: 140px;
}

.scan-ring {
	width: 90px;
	height: 90px;
	border-radius: 50%;
	border: 1px solid var(--line);
	animation: pulse 2.4s var(--ease) infinite;
}

.scan-dot {
	width: 12px;
	height: 12px;
	border-radius: 50%;
	background: var(--ink);
	position: absolute;
}

.features {
	padding: var(--section-pad) 0;
	background: #f1eee8;
}

.feature-head {
	display: grid;
	gap: 10px;
	margin-bottom: 32px;
}

.feature-head h2 {
	font-family: 'Canela', 'Instrument Serif', serif;
	font-size: clamp(2rem, 3vw, 3rem);
	margin: 0;
}

.feature-grid {
	display: grid;
	grid-template-columns: repeat(2, minmax(0, 1fr));
	gap: var(--feature-gap);
}

.feature-card {
	background: var(--paper);
	border: 1px solid var(--line);
	border-radius: var(--radius-lg);
	padding: var(--feature-card-pad);
	box-shadow: var(--shadow-soft);
	min-height: var(--feature-card-min);
}

.feature-card:nth-child(2n) {
	background: var(--feature-alt);
}

.feature-card h3 {
	font-size: 1.6rem;
	margin: 0 0 12px;
	font-family: 'Canela', 'Instrument Serif', serif;
}

.feature-card p {
	margin: 0;
	color: var(--ink-soft);
}

.qr-moment {
	padding: calc(var(--section-pad) + 20px) 0;
	background: var(--bg);
}

.qr-wrap {
	display: grid;
	grid-template-columns: 1fr 1fr;
	gap: 40px;
	align-items: center;
}

.qr-copy h2 {
	font-family: 'Canela', 'Instrument Serif', serif;
	font-size: clamp(2rem, 3vw, 3rem);
	margin: 0 0 12px;
}

.qr-stage {
	background: var(--paper);
	border-radius: 32px;
	padding: var(--qr-stage-pad);
	box-shadow: var(--shadow-float);
	display: grid;
	justify-items: center;
	gap: 14px;
	border: 1px solid var(--line);
}

.qr-mode {
	font-family: 'IBM Plex Mono', monospace;
	letter-spacing: 0.12em;
	font-size: 0.75rem;
	text-transform: uppercase;
	color: var(--muted);
}

.qr-svg.xl {
	width: var(--qr-size);
	height: var(--qr-size);
}

.qr-url {
	font-size: 1rem;
	font-weight: 500;
}

.qr-ritual {
	font-family: 'IBM Plex Mono', monospace;
	font-size: 0.8rem;
	letter-spacing: 0.12em;
	text-transform: uppercase;
	color: var(--muted);
}

.contact {
	padding: var(--contact-pad) 0;
	background: var(--paper);
	border-top: 1px solid var(--line);
}

.contact-inner {
	display: flex;
	justify-content: space-between;
	gap: 24px;
	align-items: center;
}

.contact-inner h2 {
	font-family: 'Canela', 'Instrument Serif', serif;
	margin: 0 0 10px;
}

.contact-actions {
	display: grid;
	gap: 10px;
	justify-items: start;
}

.site-footer {
	padding: var(--footer-pad-top) 0 60px;
	background: var(--paper);
}

.footer-inner {
	display: flex;
	justify-content: space-between;
	align-items: center;
	font-size: 0.9rem;
	color: var(--muted);
}

@keyframes floatIn {
