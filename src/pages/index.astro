---
import BaseHead from '../components/BaseHead.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../config';
import { ArrowRight } from 'lucide';
import storeLinks from '../data/links.json';
---

<!DOCTYPE html>
<html lang="en-us">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Instrument+Serif:opsz@8..144&family=IBM+Plex+Sans:wght@300;400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap"
		/>
	</head>
	<body>
		<header class="site-header">
			<div class="container header-inner">
				<div class="logo">Blurb</div>
				<nav class="nav">
					<a class="pill" href={storeLinks.playstore}>Download</a>
				</nav>
			</div>
		</header>

		<main>
			<section class="hero" id="top">
				<div class="container hero-grid">
					<div class="hero-copy">
					<p class="eyebrow">For meetups and in-person intros</p>
					<h1>Share who you are instantly.</h1>
					<p class="lead">Your identity, ready to share.<br />Save your links once and share them instantly.</p>
					<div class="hero-actions">
						<a class="cta" href={storeLinks.playstore}>View on Play Store</a>
						<a class="ghost" href="#contact">Contact</a>
					</div>
					</div>
					<div class="hero-media">
						<div class="giant-qr" aria-hidden="true">
							<svg viewBox="0 0 120 120" role="presentation">
								<rect width="120" height="120" fill="white" />
								<g fill="black">
									<rect x="8" y="8" width="24" height="24" />
									<rect x="88" y="8" width="24" height="24" />
									<rect x="8" y="88" width="24" height="24" />
									<rect x="44" y="44" width="12" height="12" />
									<rect x="60" y="44" width="12" height="12" />
									<rect x="44" y="60" width="12" height="12" />
									<rect x="60" y="60" width="12" height="12" />
									<rect x="72" y="28" width="8" height="8" />
									<rect x="28" y="72" width="8" height="8" />
								</g>
							</svg>
						</div>
						<div class="device">
							<div class="device-speaker"></div>
							<div class="device-screen">
								<div class="device-brand">blurb.</div>
								<div class="device-qr">
									<svg class="qr-svg" viewBox="0 0 120 120" role="img" aria-label="QR code">
										<rect width="120" height="120" fill="#f5f5f5" />
										<g fill="#0d0d0d">
											<rect x="8" y="8" width="28" height="28" />
											<rect x="84" y="8" width="28" height="28" />
											<rect x="8" y="84" width="28" height="28" />
											<rect x="48" y="48" width="10" height="10" />
											<rect x="60" y="48" width="10" height="10" />
											<rect x="72" y="48" width="10" height="10" />
											<rect x="48" y="60" width="10" height="10" />
											<rect x="60" y="60" width="10" height="10" />
											<rect x="72" y="60" width="10" height="10" />
											<rect x="48" y="72" width="10" height="10" />
											<rect x="60" y="72" width="10" height="10" />
											<rect x="72" y="72" width="10" height="10" />
										</g>
									</svg>
								</div>
								<div class="device-caption">Scan to open</div>
								<div class="device-url">prnsh.site</div>
							</div>
						</div>
					</div>
				</div>
			</section>

			<section id="flow" class="flow">
				<div class="container flow-head">
					<h2>How it works in real life.</h2>
					<p>Blurb is just a quicker way to share who you are during a meetup.</p>
				</div>
				<div class="flow-rail">
					<article class="flow-panel">
						<span class="flow-index">01</span>
						<h3>Save your links</h3>
						<p>Add your socials, website, or any profile you want to share.</p>
						<div class="flow-visual phone-list">
							<div class="flow-card">
								<span>prnsh.site</span>
								<span class="badge">QR</span>
							</div>
							<div class="flow-card muted">
								<span>x.com/prnshtwt</span>
								<span class="badge">QR</span>
							</div>
						</div>
					</article>
					<article class="flow-panel">
						<span class="flow-index">02</span>
						<h3>Show the QR</h3>
						<p>Instead of spelling out usernames, just open the card and let them scan.</p>
						<div class="flow-visual qr-full">
							<div class="qr-frame">
								<svg class="qr-svg" viewBox="0 0 120 120" role="presentation">
									<rect width="120" height="120" fill="#f5f5f5" />
									<g fill="#0d0d0d">
										<rect x="8" y="8" width="28" height="28" />
										<rect x="84" y="8" width="28" height="28" />
										<rect x="8" y="84" width="28" height="28" />
										<rect x="48" y="48" width="10" height="10" />
										<rect x="60" y="48" width="10" height="10" />
										<rect x="72" y="48" width="10" height="10" />
										<rect x="48" y="60" width="10" height="10" />
										<rect x="60" y="60" width="10" height="10" />
										<rect x="72" y="60" width="10" height="10" />
										<rect x="48" y="72" width="10" height="10" />
										<rect x="60" y="72" width="10" height="10" />
										<rect x="72" y="72" width="10" height="10" />
									</g>
								</svg>
							</div>
							<span class="qr-label">prnsh.site</span>
						</div>
					</article>
					<article class="flow-panel">
						<span class="flow-index">03</span>
						<h3>They get your page</h3>
						<p>One scan takes them straight to your link, like handing over a visiting card.</p>
						<div class="flow-visual scan">
							<div class="scan-ring"></div>
							<div class="scan-dot"></div>
							<span>Open in browser</span>
						</div>
					</article>
				</div>
			</section>

			<section class="features">
				<div class="container feature-head">
					<h2>Why people use it.</h2>
				<p>It keeps sharing simple, quick, and a lot less awkward.</p>
				</div>
				<div class="container feature-grid">
					<div class="feature-card">
						<h3>No handle hunting</h3>
					<p>No typing your name out or waiting for someone to search for you.</p>
					</div>
					<div class="feature-card">
						<h3>Faster sharing</h3>
					<p>Your links are ready before the conversation even starts.</p>
					</div>
					<div class="feature-card">
						<h3>One place for everything</h3>
						<p>Keep your website, socials, and other profiles in one app.</p>
					</div>
					<div class="feature-card">
						<h3>Like a visiting card</h3>
						<p>Except it opens the actual page immediately instead of sitting in someone’s pocket.</p>
					</div>
				</div>
			</section>

			<section class="qr-moment">
				<div class="container qr-wrap">
					<div class="qr-copy">
						<h2>One scan takes them straight to your page.</h2>
						<p>No typing your name. No searching for your profile.</p>
					</div>
					<div class="qr-stage">
						<span class="qr-mode">QR view</span>
					<svg class="qr-svg xl" viewBox="0 0 120 120" role="presentation">
						<rect width="120" height="120" fill="#f5f5f5" />
						<g fill="#0d0d0d">
								<rect x="8" y="8" width="28" height="28" />
								<rect x="84" y="8" width="28" height="28" />
								<rect x="8" y="84" width="28" height="28" />
								<rect x="48" y="48" width="10" height="10" />
								<rect x="60" y="48" width="10" height="10" />
								<rect x="72" y="48" width="10" height="10" />
								<rect x="48" y="60" width="10" height="10" />
								<rect x="60" y="60" width="10" height="10" />
								<rect x="72" y="60" width="10" height="10" />
								<rect x="48" y="72" width="10" height="10" />
								<rect x="60" y="72" width="10" height="10" />
								<rect x="72" y="72" width="10" height="10" />
							</g>
					</svg>
					<span class="qr-url">prnsh.site</span>
					<span class="qr-ritual">Scan → open</span>
				</div>
			</div>
		</section>

			<section id="contact" class="contact">
				<div class="container contact-inner">
					<div>
						<h2>Want to talk?</h2>
						<p>Reach out for feedback, support, or anything else about the app.</p>
					</div>
					<div class="contact-actions">
						<a class="contact-cta" href="mailto:hey@prnsh.site">
							<span class="contact-cta-copy">
								<span class="contact-cta-label">Email</span>
								<span class="contact-cta-address">hey@prnsh.site</span>
							</span>
							<span class="contact-cta-arrow" aria-hidden="true">
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
									{ArrowRight.map(([tag, attrs]) => (
										tag === 'path' ? <path {...attrs} /> : null
									))}
								</svg>
							</span>
						</a>
					</div>
				</div>
			</section>
		</main>

		<footer class="site-footer">
			<div class="container footer-inner">
				<p>Blurb is a simple way to share your identity quickly at meetups.</p>
				<a href="mailto:hey@prnsh.site">Contact</a>
			</div>
		</footer>
	</body>
</html>

<style>
:global(:root) {
	--bg: #f6f4ef;
	--ink: #0d0d0d;
	--ink-soft: #2c2c2c;
	--muted: #7b7b7b;
	--paper: #ffffff;
	--line: rgba(0, 0, 0, 0.12);
	--accent: #0d0d0d;
	--accent-soft: rgba(0, 0, 0, 0.08);
	--grain: rgba(0, 0, 0, 0.03);
	--shadow-soft: 0 10px 30px rgba(0, 0, 0, 0.08);
	--shadow-float: 0 40px 80px rgba(0, 0, 0, 0.18);
	--shadow-device: 0 60px 120px rgba(0, 0, 0, 0.35);
	--radius-lg: 24px;
	--radius-md: 14px;
	--radius-sm: 8px;
	--radius-pill: 999px;
	--ease: cubic-bezier(0.22, 1, 0.36, 1);
	--section-pad: 96px;
	--hero-pad: clamp(6rem, 10vh, 10rem);
	--hero-gap: 44px;
	--hero-max-width: 680px;
	--hero-lead-size: 1.06rem;
	--hero-lead-width: 620px;
	--hero-bg: radial-gradient(circle at 40% 30%, #ffffff 0%, #f6f4ef 45%, #ece9e2 100%);
	--hero-qr-size: 400px;
	--hero-qr-opacity: 0.04;
	--device-width: min(360px, 68vw);
	--device-pad: 26px;
	--device-screen-pad: 24px;
	--device-screen-min: 440px;
	--device-qr-size: 170px;
	--flow-gap: 20px;
	--flow-panel-pad: 26px;
	--flow-rail-pad: 12px;
	--flow-visual-bg: #efece6;
	--flow-card-font: 0.92rem;
	--feature-gap: 24px;
	--feature-card-pad: 30px;
	--feature-card-min: 190px;
	--feature-alt: #faf8f2;
	--qr-stage-pad: 44px;
	--qr-size: 300px;
	--contact-pad: 64px;
	--footer-pad-top: 32px;
	--ease-soft: cubic-bezier(0.28, 0.84, 0.42, 1);
}

:global(body) {
	margin: 0;
	padding: 0;
	max-width: 100%;
	font-family: 'Sohne', 'IBM Plex Sans', sans-serif;
	font-size: 1.05rem;
	color: var(--ink);
	background: var(--bg);
	line-height: 1.6;
}

:global(body)::before {
	content: '';
	position: fixed;
	inset: 0;
	pointer-events: none;
	opacity: 0.22;
	mix-blend-mode: multiply;
	background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='220' height='220'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='3'/></filter><rect width='220' height='220' filter='url(%23n)' opacity='0.25'/></svg>");
	z-index: 0;
}

:global(body)::after {
	content: '';
	position: fixed;
	inset: -10% 0 0 0;
	pointer-events: none;
	background: radial-gradient(circle at 50% 20%, rgba(255, 255, 255, 0.6), transparent 70%);
	opacity: 0.7;
	z-index: 0;
}

:global(*) {
	box-sizing: border-box;
}

:global(a) {
	color: inherit;
	text-decoration: none;
}

main {
	position: relative;
	z-index: 1;
}

.container {
	width: min(1160px, 90vw);
	margin: 0 auto;
}

.site-header {
	position: sticky;
	top: 0;
	z-index: 10;
	background: rgba(246, 244, 239, 0.7);
	backdrop-filter: blur(10px);
	border-bottom: 1px solid var(--line);
}

.header-inner {
	display: flex;
	align-items: center;
	justify-content: space-between;
	padding: 18px 0;
}

.logo {
	font-family: 'Canela', 'Instrument Serif', serif;
	font-size: 1.2rem;
	letter-spacing: -0.02em;
}

.nav {
	display: flex;
	gap: 16px;
	align-items: center;
	font-size: 0.93rem;
}

.pill {
	border: 1px solid var(--line);
	padding: 10px 18px;
	border-radius: var(--radius-pill);
}

.hero {
	background: var(--hero-bg);
	padding: var(--hero-pad) 0;
	overflow: hidden;
}

.hero-grid {
	display: grid;
	grid-template-columns: 6fr 6fr;
	gap: var(--hero-gap);
	align-items: center;
}

.hero-copy {
	display: grid;
	gap: 22px;
	max-width: var(--hero-max-width);
}

.eyebrow {
	font-size: 0.75rem;
	letter-spacing: 0.14em;
	text-transform: uppercase;
	color: var(--muted);
	font-family: 'IBM Plex Mono', monospace;
}

.hero h1 {
	font-family: 'Canela', 'Instrument Serif', serif;
	font-weight: 500;
	font-size: clamp(3rem, 5vw, 5.2rem);
	letter-spacing: -0.02em;
	line-height: 1.03;
	margin: 0;
}

.lead {
	font-size: var(--hero-lead-size);
	color: var(--ink-soft);
	margin: 0;
	max-width: var(--hero-lead-width);
}

.hero-actions {
	display: flex;
	gap: 12px;
	flex-wrap: wrap;
}

.cta {
	position: relative;
	overflow: hidden;
	background: var(--accent);
	color: var(--paper);
	padding: 11px 22px;
	border-radius: var(--radius-pill);
	font-weight: 500;
	transition: box-shadow 0.22s var(--ease-soft), background-color 0.22s var(--ease-soft),
		filter 0.22s var(--ease-soft);
	box-shadow: var(--shadow-soft);
}

.cta::after {
	content: '';
	position: absolute;
	inset: 1px;
	border-radius: inherit;
	background: linear-gradient(180deg, rgba(255, 255, 255, 0.1), transparent 48%);
	opacity: 0;
	transition: opacity 0.22s var(--ease-soft);
	pointer-events: none;
}

.cta:hover {
	box-shadow: 0 14px 28px rgba(0, 0, 0, 0.12);
	filter: brightness(1.02);
}

.cta:hover::after {
	opacity: 1;
}

.cta:active {
	filter: brightness(0.98);
	box-shadow: 0 8px 18px rgba(0, 0, 0, 0.12);
}

.ghost {
	position: relative;
	overflow: hidden;
	border: 1px solid var(--line);
	padding: 11px 20px;
	border-radius: var(--radius-pill);
	transition: border-color 0.22s var(--ease-soft), background-color 0.22s var(--ease-soft),
		box-shadow 0.22s var(--ease-soft);
}

.ghost:hover {
	border-color: var(--ink-soft);
	background: rgba(255, 255, 255, 0.62);
	box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.55);
}

.ghost:active {
	background: rgba(255, 255, 255, 0.72);
}

.hero-media {
	position: relative;
	display: grid;
	place-items: center;
}

.giant-qr {
	position: absolute;
	right: -40px;
	top: -40px;
	width: var(--hero-qr-size);
	height: var(--hero-qr-size);
	opacity: var(--hero-qr-opacity);
}

.giant-qr svg {
	width: 100%;
	height: 100%;
}

.device {
	position: relative;
	width: var(--device-width);
	border-radius: 38px;
	background: #0b0c0e;
	padding: var(--device-pad);
	box-shadow: var(--shadow-device);
	transform: rotate(-4deg);
	animation: floatIn 0.8s var(--ease-soft) both 0.28s, deviceDrift 6.5s ease-in-out 1.1s infinite;
	will-change: transform;
}

.device-speaker {
	width: 160px;
	height: 16px;
	border-radius: 999px;
	background: #151618;
	margin: 0 auto 18px;
}

.device-screen {
	background: linear-gradient(160deg, #111317 0%, #070707 60%, #050505 100%);
	border-radius: 28px;
	padding: var(--device-screen-pad);
	min-height: var(--device-screen-min);
	color: #f4f4f2;
	display: grid;
	gap: 20px;
	justify-items: center;
	text-align: center;
	box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.06);
}

.device-brand {
	font-family: 'Canela', 'Instrument Serif', serif;
	font-size: 1.55rem;
	justify-self: start;
}

.device-qr {
	width: var(--device-qr-size);
	height: var(--device-qr-size);
	border-radius: 20px;
	background: #f5f5f5;
	padding: 12px;
	box-shadow: var(--shadow-soft);
}

.qr-svg {
	width: 100%;
	height: 100%;
}

.device-caption {
	font-size: 0.85rem;
	letter-spacing: 0.14em;
	text-transform: uppercase;
	color: rgba(244, 244, 242, 0.6);
	font-family: 'IBM Plex Mono', monospace;
}

.device-url {
	font-size: 1.05rem;
	font-weight: 500;
}

.flow {
	padding: var(--section-pad) 0;
}

.flow-head {
	display: grid;
	gap: 10px;
	margin-bottom: 28px;
}

.flow-head h2 {
	font-family: 'Canela', 'Instrument Serif', serif;
	font-size: clamp(2rem, 3vw, 3rem);
	margin: 0;
}

.flow-rail {
	display: grid;
	grid-auto-flow: column;
	grid-auto-columns: minmax(280px, 420px);
	gap: var(--flow-gap);
	overflow-x: auto;
	scroll-snap-type: x mandatory;
	padding: var(--flow-rail-pad) 0 var(--flow-rail-pad) 5vw;
}

.flow-panel {
	background: var(--paper);
	border: 1px solid var(--line);
	border-radius: var(--radius-lg);
	padding: var(--flow-panel-pad);
	display: grid;
	gap: 14px;
	min-height: 300px;
	scroll-snap-align: start;
	box-shadow: var(--shadow-soft);
}

.flow-index {
	font-family: 'IBM Plex Mono', monospace;
	color: var(--muted);
	letter-spacing: 0.18em;
	font-size: 0.75rem;
	text-transform: uppercase;
}

.flow-panel h3 {
	margin: 0;
	font-size: clamp(1.4rem, 2vw, 1.8rem);
	line-height: 1.15;
}

.flow-panel p {
	margin: 0;
	color: var(--ink-soft);
}

.flow-visual {
	margin-top: auto;
	padding: 14px;
	border-radius: 18px;
	background: var(--flow-visual-bg);
	display: grid;
	gap: 12px;
}

.flow-card {
	display: flex;
	justify-content: space-between;
	padding: 12px 14px;
	border-radius: 14px;
	background: #fff;
	border: 1px solid var(--line);
	font-size: var(--flow-card-font);
}

.flow-card.muted {
	opacity: 0.7;
}

.badge {
	font-size: 0.75rem;
	border: 1px solid var(--line);
	padding: 4px 9px;
	border-radius: var(--radius-pill);
}

.qr-full .qr-frame {
	background: #fff;
	border-radius: 16px;
	padding: 12px;
	box-shadow: var(--shadow-soft);
}

.qr-label {
	font-size: 0.85rem;
	font-family: 'IBM Plex Mono', monospace;
	color: var(--muted);
}

.scan {
	display: grid;
	place-items: center;
	gap: 12px;
	position: relative;
	min-height: 140px;
}

.scan-ring {
	width: 90px;
	height: 90px;
	border-radius: 50%;
	border: 1px solid var(--line);
	animation: pulse 2.8s var(--ease-soft) infinite;
}

.scan-dot {
	width: 12px;
	height: 12px;
	border-radius: 50%;
	background: var(--ink);
	position: absolute;
}

.features {
	padding: var(--section-pad) 0;
	background: #f3f0ea;
}

.feature-head {
	display: grid;
	gap: 10px;
	margin-bottom: 32px;
}

.feature-head h2 {
	font-family: 'Canela', 'Instrument Serif', serif;
	font-size: clamp(2rem, 3vw, 3rem);
	margin: 0;
}

.feature-grid {
	display: grid;
	grid-template-columns: repeat(2, minmax(0, 1fr));
	gap: var(--feature-gap);
}

.feature-card {
	background: var(--paper);
	border: 1px solid var(--line);
	border-radius: var(--radius-lg);
	padding: var(--feature-card-pad);
	box-shadow: var(--shadow-soft);
	min-height: var(--feature-card-min);
}

.feature-card:nth-child(2n) {
	background: var(--feature-alt);
}

.feature-card h3 {
	font-size: 1.6rem;
	margin: 0 0 12px;
	font-family: 'Canela', 'Instrument Serif', serif;
}

.feature-card p {
	margin: 0;
	color: var(--ink-soft);
}

.qr-moment {
