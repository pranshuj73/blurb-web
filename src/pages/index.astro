---
import BaseHead from '../components/BaseHead.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../config';
---

<!DOCTYPE html>
<html lang="en-us">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=IBM+Plex+Sans:wght@300;400;500;600&display=swap"
		/>
	</head>
	<body>
		<header class="site-header">
			<div class="container header-inner">
				<div class="logo">
					<span class="logo-mark"></span>
					<span>{SITE_TITLE}</span>
				</div>
				<nav class="nav">
					<a href="/privacy-policy">Privacy</a>
					<a class="cta" href="#early-access">Get early access</a>
				</nav>
			</div>
		</header>

		<main>
			<section class="hero">
				<div class="hero-grid">
					<div class="hero-copy">
						<p class="eyebrow">Minimalist digital cards for real-world moments</p>
						<h1>Blurb makes in-person networking feel instant.</h1>
						<p class="lead">
							Save a link once. Show a clean QR on the spot. Let people open your profile
							immediately without searching, waiting, or sharing your number.
						</p>
						<div class="actions">
							<a class="cta" href="#early-access">Join the waitlist</a>
							<a class="ghost" href="#flow">See how it works</a>
						</div>
						<div class="micro-proof">
							<span>Instant QR</span>
							<span>Zero friction</span>
							<span>Privacy-first</span>
						</div>
					</div>
					<div class="hero-media">
						<div class="media-frame">
							<img
								src="https://images.unsplash.com/photo-1522075469751-3a6694fb2f61?auto=format&fit=crop&w=1200&q=80"
								alt="Two people connecting over a phone in a bright cafe"
								loading="lazy"
							/>
							<div class="qr-overlay">
								<div class="qr-box"></div>
								<p>Open my profile</p>
							</div>
						</div>
					</div>
				</div>
				<div class="hero-glow"></div>
			</section>

			<section id="flow" class="flow">
				<div class="container flow-grid">
					<div class="flow-sticky">
						<h2>Three steps. One clean connection.</h2>
						<p>
							Blurb is built for real-life intros. Create a card, show the QR, and let
							people jump straight to your profile.
						</p>
					</div>
					<ol class="flow-steps">
						<li>
							<h3>Create a card</h3>
							<p>Open the app, paste a website or social link, and save it to your list.</p>
						</li>
						<li>
							<h3>Share instantly</h3>
							<p>Tap a card to open a fullscreen QR, ready for scanning on the spot.</p>
						</li>
						<li>
							<h3>Connect without friction</h3>
							<p>
								They scan and land directly on your profile or site, no searching or
								phone-number swaps.
							</p>
						</li>
					</ol>
				</div>
			</section>

			<section class="features">
				<div class="container features-grid">
					<div>
						<h2>Designed for the seconds that matter.</h2>
						<p>
							No handle hunting. No awkward follow requests. Blurb keeps your
							introduction crisp and your follow-up automatic.
						</p>
						<ul>
							<li>One-tap fullscreen QR with a high-contrast scan target.</li>
							<li>Organized list of links, ready to show as different cards.</li>
							<li>Privacy-first by default — share what you want, nothing more.</li>
						</ul>
					</div>
					<div class="feature-panel">
						<p class="panel-label">Live moment view</p>
						<div class="panel-screen">
							<div class="panel-card">
								<div>
									<p class="name">Taylor W.</p>
									<p class="role">Product Design · blurb.is/taylor</p>
								</div>
								<div class="qr-mini"></div>
							</div>
							<div class="panel-card ghost">
								<div>
									<p class="name">Studio Portfolio</p>
									<p class="role">blurb.is/studio</p>
								</div>
								<div class="qr-mini"></div>
							</div>
						</div>
						<p class="panel-note">Tap a card → show QR instantly.</p>
					</div>
				</div>
			</section>

			<section class="detail">
				<div class="container detail-grid">
					<div class="detail-image"></div>
					<div class="detail-copy">
						<h2>Keep your contact info yours.</h2>
						<p>
							Share a single link, keep your personal number private, and make it easy
							for people to follow up on their own time.
						</p>
						<a class="text-link" href="/privacy-policy">Read the privacy policy</a>
					</div>
				</div>
			</section>

			<section id="early-access" class="cta-section">
				<div class="container cta-grid">
					<div>
						<h2>Be ready before the next intro.</h2>
						<p>
							Join the early list and get the first release when Blurb launches.
						</p>
					</div>
					<div class="cta-actions">
						<a class="cta" href="mailto:hello@blurb.app">Request early access</a>
						<span>hello@blurb.app</span>
					</div>
				</div>
			</section>
		</main>

		<footer class="site-footer">
			<div class="container footer-inner">
				<p>Blurb is a minimalist digital card app for in-person networking.</p>
				<div class="footer-links">
					<a href="/privacy-policy">Privacy policy</a>
					<a href="mailto:hello@blurb.app">Contact</a>
				</div>
			</div>
		</footer>
	</body>
</html>

<style>
:global(body) {
	margin: 0;
	padding: 0;
	max-width: 100%;
	font-family: 'IBM Plex Sans', system-ui, -apple-system, sans-serif;
	color: #171717;
	background: #f3f1ec;
}

:global(*) {
	box-sizing: border-box;
}

:global(a) {
	color: inherit;
	text-decoration: none;
}

main {
	overflow: hidden;
}

.container {
	width: min(1120px, 90vw);
	margin: 0 auto;
}

.site-header {
	position: sticky;
	top: 0;
	z-index: 10;
	background: rgba(243, 241, 236, 0.9);
	backdrop-filter: blur(12px);
	border-bottom: 1px solid rgba(23, 23, 23, 0.08);
}

.header-inner {
	display: flex;
	align-items: center;
	justify-content: space-between;
	padding: 18px 0;
}

.logo {
	display: flex;
	align-items: center;
	gap: 12px;
	font-family: 'Space Grotesk', sans-serif;
	font-weight: 600;
	letter-spacing: -0.02em;
}

.logo-mark {
	width: 14px;
	height: 14px;
	background: #111;
	border-radius: 50%;
	box-shadow: 0 0 0 6px rgba(17, 17, 17, 0.15);
	animation: pulse 5s ease-in-out infinite;
}

.nav {
	display: flex;
	gap: 18px;
	align-items: center;
	font-size: 0.95rem;
}

.cta {
	background: #111;
	color: #f7f4ef;
	padding: 12px 22px;
	border-radius: 999px;
	font-weight: 500;
	transition: transform 0.2s ease, box-shadow 0.2s ease;
	box-shadow: 0 12px 24px rgba(0, 0, 0, 0.2);
}

.cta:hover {
	transform: translateY(-2px);
	box-shadow: 0 16px 30px rgba(0, 0, 0, 0.25);
}

.hero {
	position: relative;
	padding: 96px 0 80px;
	background: linear-gradient(120deg, #f7f5f0 0%, #ece8df 45%, #e0dfdb 100%);
}

.hero-grid {
	width: min(1200px, 92vw);
	margin: 0 auto;
	display: grid;
	grid-template-columns: repeat(2, minmax(0, 1fr));
	gap: 48px;
	align-items: center;
}

.hero-copy {
	display: grid;
	gap: 20px;
	max-width: 520px;
	animation: rise 0.8s ease-out both;
}

.eyebrow {
	text-transform: uppercase;
	letter-spacing: 0.22em;
	font-size: 0.72rem;
	color: #5b5b5b;
	font-weight: 600;
}

.hero h1 {
	font-family: 'Space Grotesk', sans-serif;
	font-size: clamp(2.6rem, 4vw, 4rem);
	letter-spacing: -0.03em;
	margin: 0;
}

.lead {
	font-size: 1.15rem;
	color: #333;
	line-height: 1.7;
}

.actions {
	display: flex;
	gap: 16px;
	flex-wrap: wrap;
}

.ghost {
	border: 1px solid rgba(17, 17, 17, 0.2);
	padding: 12px 20px;
	border-radius: 999px;
	transition: border 0.2s ease, transform 0.2s ease;
	font-weight: 500;
}

.ghost:hover {
	border-color: rgba(17, 17, 17, 0.5);
	transform: translateY(-2px);
}

.micro-proof {
	display: flex;
	gap: 18px;
	font-size: 0.9rem;
	color: #666;
}

.hero-media {
	position: relative;
	animation: fadeIn 0.9s ease-out both 0.2s;
}

.media-frame {
	position: relative;
	border-radius: 28px;
	overflow: hidden;
	box-shadow: 0 30px 60px rgba(0, 0, 0, 0.2);
}

.media-frame img {
	width: 100%;
	height: 520px;
	object-fit: cover;
	display: block;
}

.qr-overlay {
	position: absolute;
	bottom: 24px;
	left: 24px;
	background: rgba(255, 255, 255, 0.92);
	padding: 16px 18px;
	border-radius: 18px;
	width: 180px;
	backdrop-filter: blur(6px);
	display: grid;
	gap: 10px;
	font-size: 0.85rem;
	font-weight: 600;
	animation: float 3.8s ease-in-out infinite;
}

.qr-box {
	width: 64px;
	height: 64px;
	border-radius: 12px;
	background:
		linear-gradient(135deg, #111 0%, #111 45%, #fff 45%, #fff 100%);
	border: 2px solid #111;
}

.hero-glow {
	position: absolute;
	width: 320px;
	height: 320px;
	border-radius: 50%;
	background: radial-gradient(circle, rgba(17, 17, 17, 0.18), transparent 70%);
	top: 8%;
	right: 6%;
	filter: blur(6px);
	opacity: 0.4;
}

.flow {
	padding: 90px 0;
	background: #fdfcf9;
}

.flow-grid {
	display: grid;
	grid-template-columns: 0.9fr 1.1fr;
	gap: 48px;
}

.flow-sticky {
	position: sticky;
	top: 96px;
	align-self: start;
	display: grid;
	gap: 18px;
}

.flow h2,
.features h2,
.detail h2,
.cta-section h2 {
	font-family: 'Space Grotesk', sans-serif;
	font-size: clamp(2rem, 3vw, 2.8rem);
	margin: 0;
}

.flow-steps {
	list-style: none;
	margin: 0;
	padding: 0;
	display: grid;
	gap: 28px;
}

.flow-steps li {
	padding: 26px 28px;
	border: 1px solid rgba(17, 17, 17, 0.08);
	border-radius: 22px;
	background: #ffffff;
	box-shadow: 0 18px 40px rgba(17, 17, 17, 0.08);
	animation: rise 0.9s ease-out both;
}

.flow-steps h3 {
	margin: 0 0 10px;
	font-family: 'Space Grotesk', sans-serif;
}

.flow-steps p {
	margin: 0;
	color: #4b4b4b;
}

.features {
	padding: 90px 0;
	background: #f2efe8;
}

.features-grid {
	display: grid;
	grid-template-columns: 1fr 0.9fr;
	gap: 48px;
	align-items: center;
}

.features ul {
	margin: 24px 0 0;
	padding-left: 20px;
	color: #3d3d3d;
	line-height: 1.7;
}

.feature-panel {
	background: #141414;
	color: #f9f6f1;
	padding: 28px;
	border-radius: 24px;
	display: grid;
	gap: 18px;
	box-shadow: 0 24px 50px rgba(0, 0, 0, 0.25);
}

.panel-label {
	text-transform: uppercase;
	letter-spacing: 0.3em;
	font-size: 0.7rem;
	color: rgba(255, 255, 255, 0.6);
}

.panel-screen {
	display: grid;
	gap: 14px;
}

.panel-card {
	display: flex;
	justify-content: space-between;
	align-items: center;
	background: rgba(255, 255, 255, 0.08);
	border-radius: 16px;
	padding: 16px 18px;
}

.panel-card.ghost {
	opacity: 0.6;
}

.name {
	margin: 0;
	font-weight: 600;
}

.role {
	margin: 4px 0 0;
	font-size: 0.85rem;
	color: rgba(255, 255, 255, 0.7);
}

.qr-mini {
	width: 44px;
	height: 44px;
	border-radius: 10px;
	background: repeating-linear-gradient(135deg, #f9f6f1, #f9f6f1 6px, #1a1a1a 6px, #1a1a1a 12px);
}

.panel-note {
	font-size: 0.85rem;
	color: rgba(255, 255, 255, 0.6);
}

.detail {
	padding: 100px 0;
	background: #f9f7f1;
}

.detail-grid {
	display: grid;
	grid-template-columns: 0.9fr 1.1fr;
	gap: 48px;
	align-items: center;
}

.detail-image {
	height: 380px;
	border-radius: 26px;
	background:
		linear-gradient(rgba(15, 15, 15, 0.2), rgba(15, 15, 15, 0.55)),
		url('https://images.unsplash.com/photo-1521737604893-d14cc237f11d?auto=format&fit=crop&w=1200&q=80')
			center/cover no-repeat;
	box-shadow: 0 26px 50px rgba(0, 0, 0, 0.2);
}

.detail-copy {
	display: grid;
	gap: 16px;
}

.text-link {
	font-weight: 600;
	border-bottom: 1px solid rgba(17, 17, 17, 0.2);
	width: fit-content;
	padding-bottom: 4px;
}

.cta-section {
	padding: 80px 0 100px;
	background: #121212;
	color: #f8f4ef;
}

.cta-grid {
	display: flex;
	justify-content: space-between;
	gap: 32px;
	align-items: center;
}

.cta-actions {
	display: grid;
	gap: 14px;
	justify-items: start;
}

.cta-actions span {
	color: rgba(248, 244, 239, 0.7);
	font-size: 0.95rem;
}

.site-footer {
	background: #0b0b0b;
	color: rgba(248, 244, 239, 0.7);
	padding: 40px 0;
}

.footer-inner {
	display: flex;
	justify-content: space-between;
	gap: 24px;
	font-size: 0.95rem;
}

.footer-links {
	display: flex;
	gap: 18px;
}

@keyframes rise {
	from {
		opacity: 0;
		transform: translateY(16px);
	}
	to {
		opacity: 1;
		transform: translateY(0);
	}
}

@keyframes fadeIn {
	from {
		opacity: 0;
		transform: scale(0.98);
	}
	to {
		opacity: 1;
		transform: scale(1);
	}
}

@keyframes float {
	0%,
	100% {
		transform: translateY(0px);
	}
	50% {
		transform: translateY(-8px);
	}
}

@keyframes pulse {
	0%,
	100% {
		box-shadow: 0 0 0 6px rgba(17, 17, 17, 0.15);
	}
	50% {
		box-shadow: 0 0 0 12px rgba(17, 17, 17, 0.08);
	}
}

@media (max-width: 900px) {
	.header-inner {
		flex-direction: column;
		gap: 12px;
	}

	.hero-grid,
	.flow-grid,
	.features-grid,
	.detail-grid {
		grid-template-columns: 1fr;
	}

	.hero-media img {
		height: 380px;
	}

	.flow-sticky {
		position: static;
	}

	.cta-grid,
	.footer-inner {
		flex-direction: column;
		align-items: flex-start;
	}
}

@media (max-width: 600px) {
	.nav {
		flex-direction: column;
		gap: 10px;
	}

	.hero {
		padding: 80px 0 60px;
	}

	.micro-proof {
		flex-direction: column;
		gap: 8px;
	}

	.feature-panel {
		padding: 22px;
	}
}

@media (prefers-reduced-motion: reduce) {
	* {
		animation: none !important;
		transition: none !important;
	}
}
</style>
